# =============================================================================
# Blinkit EDI Microservice - Environment Variables
# Copy to .env and fill in values
# =============================================================================

# Django
DJANGO_SECRET_KEY=change-me-to-a-random-string
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=your-domain.com,your-ip

# Database (PostgreSQL / Supabase)
DB_NAME=blinkit_edi
DB_USER=postgres
DB_PASSWORD=
DB_HOST=localhost
DB_PORT=5432

# Blinkit API Keys
# Key provided by Blinkit's partnersbiz team (they call us with this)
BLINKIT_INBOUND_API_KEY=
# Key we send in headers when calling Blinkit's APIs
BLINKIT_OUTBOUND_API_KEY=

# Environment: set to True when going live
BLINKIT_USE_PROD=False

# Google Sheets (for ASN import bridge)
GOOGLE_SERVICE_ACCOUNT_JSON=/path/to/service-account.json

# Logging
LOG_FILE=logs/app.log
